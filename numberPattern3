import java.util.Scanner;

public class Main {




    static void main() {
        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();

        for(int i=1;i<=n;i++){
            for(int j=1; j<=n;j++){
                System.out.print(i+j-1 + " ");
            }
            System.out.println();
        }

    }
}
